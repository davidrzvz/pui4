<%- include('../partials/header') %>

<div class="container-fluid mt-4">
    <h1 class="mb-4">Seguridad</h1>
    <p class="text-muted">Módulo simplificado para la ejecución de pruebas de seguridad reales sobre las instancias.</p>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs mb-4" id="securityTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="instances-tab" data-bs-toggle="tab" data-bs-target="#instances" type="button" role="tab">Instancias</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">Historial de Reportes</button>
        </li>
    </ul>

    <!-- Tab Contents -->
    <div class="tab-content" id="securityTabsContent">
        
        <!-- Instances Tab -->
        <div class="tab-pane fade show active" id="instances" role="tabpanel">
            <div class="card">
                <div class="card-body">
                    <div id="scan-result" class="mb-4 d-none"></div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>RFC / Empresa</th>
                                    <th>Puerto</th>
                                    <th>Estado</th>
                                    <th>Acciones de Seguridad</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (instances && instances.length > 0) { %>
                                    <% instances.forEach(function(instance) { %>
                                        <tr>
                                            <td>
                                                <strong><%= instance.rfc %></strong><br>
                                                <small class="text-muted"><%= instance.company %></small>
                                            </td>
                                            <td><%= instance.port %></td>
                                            <td>
                                                <% if (instance.status === 'online') { %>
                                                    <span class="badge bg-success">Online</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Offline</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" id="btn-sast-<%= instance.id %>" onclick="executeSecurityScan('sast', '<%= instance.id %>', this)">
                                                    <i class="bi bi-code-slash"></i> Ejecutar SAST
                                                </button>
                                                <button class="btn btn-sm btn-outline-warning" id="btn-sca-<%= instance.id %>" onclick="executeSecurityScan('sca', '<%= instance.id %>', this)">
                                                    <i class="bi bi-box-seam"></i> Ejecutar SCA
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" id="btn-dast-<%= instance.id %>" onclick="executeSecurityScan('dast', '<%= instance.id %>', this)">
                                                    <i class="bi bi-globe"></i> Ejecutar DAST
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="text-center">No hay instancias administradas.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- History Tab -->
        <div class="tab-pane fade" id="history" role="tabpanel">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Historial de Reportes</h5>
                    <button class="btn btn-sm btn-outline-secondary" onclick="loadHistory()">
                        <i class="bi bi-arrow-clockwise"></i> Refrescar
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Herramienta</th>
                                    <th>Resultado</th>
                                    <th>PDF</th>
                                    <th>HTML</th>
                                </tr>
                            </thead>
                            <tbody id="history-table-body">
                                <tr><td colspan="6" class="text-center">Cargando historial...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    async function executeSecurityScan(type, instanceId, btnElement) {
        const resultDiv = document.getElementById('scan-result');
        const originalHtml = btnElement.innerHTML;
        
        btnElement.disabled = true;
        btnElement.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Ejecutando...';
        
        resultDiv.classList.add('d-none');
        resultDiv.innerHTML = '';

        try {
            const res = await fetch(`/security/api/execute/${type}/${instanceId}`, { method: 'POST' });
            const data = await res.json();
            
            if (data.success) {
                const r = data.data;
                resultDiv.innerHTML = `
                    <div class="alert alert-success">
                        <h4 class="alert-heading"><i class="bi bi-check-circle-fill"></i> Análisis ${type.toUpperCase()} Finalizado</h4>
                        <hr>
                        <div class="row">
                            <div class="col-md-6">
                                <p class="mb-1"><strong>Herramienta:</strong> ${r.tool}</p>
                                <p class="mb-1"><strong>Duración:</strong> ${r.duration}</p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-1"><strong>Estado:</strong> ${r.status}</p>
                                <p class="mb-1"><strong>Hallazgos:</strong> <span class="badge ${r.findings.length > 0 ? 'bg-danger' : 'bg-success'}">${r.findings.length}</span></p>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="/security/api/download/pdf/${data.reportId}" target="_blank" class="btn btn-danger btn-sm me-2">
                                <i class="bi bi-file-earmark-pdf-fill"></i> Descargar PDF
                            </a>
                            <a href="/security/api/download/html/${data.reportId}" target="_blank" class="btn btn-info btn-sm text-white">
                                <i class="bi bi-filetype-html"></i> Descargar HTML
                            </a>
                        </div>
                    </div>
                `;
                loadHistory();
            } else {
                resultDiv.innerHTML = `<div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> Error: ${data.error}</div>`;
            }
        } catch (error) {
            resultDiv.innerHTML = `<div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> Error de red: ${error.message}</div>`;
        } finally {
            btnElement.disabled = false;
            btnElement.innerHTML = originalHtml;
            resultDiv.classList.remove('d-none');
        }
    }

    async function loadHistory() {
        const tbody = document.getElementById('history-table-body');
        try {
            const res = await fetch('/security/api/history');
            const data = await res.json();
            
            if (data.success) {
                if (data.data.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted">No hay registros en el historial.</td></tr>`;
                    return;
                }
                
                tbody.innerHTML = data.data.map(row => {
                    const localDate = new Date(row.date).toLocaleString();
                    const badgeClass = row.findings > 0 ? 'bg-danger' : 'bg-success';
                    return `
                        <tr>
                            <td>${localDate}</td>
                            <td><span class="badge bg-secondary">${row.type}</span></td>
                            <td>${row.tool}</td>
                            <td><span class="badge ${badgeClass}">${row.findings} hallazgos</span></td>
                            <td>
                                <a href="/security/api/download/pdf/${row.id}" target="_blank" class="btn btn-sm btn-outline-danger" title="Descargar PDF">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                            </td>
                            <td>
                                <a href="/security/api/download/html/${row.id}" target="_blank" class="btn btn-sm btn-outline-info" title="Descargar HTML">
                                    <i class="bi bi-filetype-html"></i>
                                </a>
                            </td>
                        </tr>
                    `;
                }).join('');
            } else {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-danger">Error cargando historial: ${data.error}</td></tr>`;
            }
        } catch (e) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center text-danger">Error de red: ${e.message}</td></tr>`;
        }
    }

    document.getElementById('history-tab').addEventListener('shown.bs.tab', loadHistory);
    document.addEventListener('DOMContentLoaded', loadHistory);
</script>

<%- include('../partials/footer') %>
