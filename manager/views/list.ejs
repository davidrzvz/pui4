<%- include('partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Instancias PUI</h3>
    <div>
        <button class="btn btn-outline-info me-2" id="btnImportInstances"><i class="bi bi-cloud-arrow-down me-1"></i> Importar existentes</button>
        <a href="/instances/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Nueva Instancia</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive" style="overflow: visible !important;">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">RFC</th>
                        <th>Empresa</th>
                        <th>Acceso</th>
                        <th>Estado</th>
                        <th>Último Backup</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (instances.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">No hay instancias registradas.</td>
                        </tr>
                    <% } else { %>
                        <% instances.forEach(instance => { %>
                            <tr>
                                <td class="align-middle ps-4 fw-bold"><%= instance.rfc %></td>
                                <td class="align-middle"><%= instance.company %></td>
                                <td class="align-middle">
                                    <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary border-opacity-25 mb-1 d-inline-block">Puerto: <%= instance.port %></span>
                                    <br>
                                    <a href="http://192.168.1.10:<%= instance.port %>/admin/login" target="_blank" class="text-decoration-none text-accent" style="font-size: 0.8rem;"><i class="bi bi-box-arrow-up-right me-1"></i>Abrir Panel</a>
                                </td>
                                <td class="align-middle">
                                    <% if (instance.status === 'online') { %>
                                        <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25"><i class="bi bi-circle-fill" style="font-size: 0.4rem; vertical-align: middle; margin-right: 4px;"></i> Online</span>
                                    <% } else { %>
                                        <span class="badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-25"><i class="bi bi-circle-fill" style="font-size: 0.4rem; vertical-align: middle; margin-right: 4px;"></i> Offline</span>
                                    <% } %>
                                </td>
                                <td class="align-middle text-muted" style="font-size: 0.85rem;">
                                    <%= instance.last_backup ? new Date(instance.last_backup).toLocaleString() : 'Nunca' %>
                                </td>
                                <td class="align-middle text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-boundary="window">
                                            Administrar
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow">
                                            <li class="dropdown-header">Gestión</li>
                                            <li><a class="dropdown-item" href="http://192.168.1.10:<%= instance.port %>/admin/login" target="_blank"><i class="bi bi-box-arrow-up-right text-primary"></i> Abrir panel</a></li>
                                            <li><button class="dropdown-item btn-action" data-action="restart" data-rfc="<%= instance.rfc %>" data-method="POST"><i class="bi bi-arrow-clockwise text-warning"></i> Reiniciar instancia</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="stop" data-rfc="<%= instance.rfc %>" data-method="POST"><i class="bi bi-stop-circle text-secondary"></i> Detener instancia</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="start" data-rfc="<%= instance.rfc %>" data-method="POST"><i class="bi bi-play-circle text-success"></i> Iniciar instancia</button></li>
                                            <li><button class="dropdown-item btn-action text-danger" data-action="delete" data-rfc="<%= instance.rfc %>" data-method="POST" data-confirm="true"><i class="bi bi-trash3-fill"></i> Eliminar instancia</button></li>
                                            
                                            <li><hr class="dropdown-divider border-secondary opacity-25"></li>
                                            <li class="dropdown-header">Respaldos</li>
                                            <li><button class="dropdown-item btn-action" data-action="backup-db" data-rfc="<%= instance.rfc %>" data-method="POST"><i class="bi bi-database-down text-info"></i> Respaldar base de datos</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="backup-files" data-rfc="<%= instance.rfc %>" data-method="POST"><i class="bi bi-file-earmark-zip text-info"></i> Respaldar archivos</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="backup-full" data-rfc="<%= instance.rfc %>" data-method="POST"><i class="bi bi-archive-fill text-info"></i> Respaldo completo</button></li>
                                            
                                            <li><hr class="dropdown-divider border-secondary opacity-25"></li>
                                            <li class="dropdown-header">Monitoreo</li>
                                            <li><button class="dropdown-item btn-action" data-action="logs" data-rfc="<%= instance.rfc %>" data-method="GET"><i class="bi bi-journal-text text-muted"></i> Ver logs en tiempo real</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="status" data-rfc="<%= instance.rfc %>" data-method="GET"><i class="bi bi-activity text-muted"></i> Estado de servicios</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="audits" data-rfc="<%= instance.rfc %>" data-method="GET"><i class="bi bi-shield-check text-muted"></i> Ver auditorías</button></li>
                                            
                                            <li><hr class="dropdown-divider border-secondary opacity-25"></li>
                                            <li class="dropdown-header">Configuración</li>
                                            <li><button class="dropdown-item btn-action" data-action="change-password-modal" data-rfc="<%= instance.rfc %>"><i class="bi bi-key-fill text-muted"></i> Ver / Cambiar Credenciales API</button></li>
                                            <li><button class="dropdown-item btn-action" data-action="config" data-rfc="<%= instance.rfc %>" data-method="GET"><i class="bi bi-gear-fill text-muted"></i> Ver Variables de Entorno</button></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="passwordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Credenciales API</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="passwordForm">
                    <input type="hidden" id="pwdRfc">
                    <div class="mb-3">
                        <label class="form-label text-muted">Instancia RFC</label>
                        <input type="text" class="form-control bg-transparent text-light border-secondary" id="pwdRfcDisplay" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Usuario API</label>
                        <input type="text" class="form-control bg-transparent text-light border-secondary" value="PUI" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Nueva Contraseña</label>
                        <input type="password" class="form-control bg-transparent text-light border-secondary" id="pwdNew" required minlength="6" placeholder="Mínimo 6 caracteres">
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSavePassword"><i class="bi bi-save me-1"></i> Guardar y Reiniciar</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const loader = document.getElementById('globalLoader');
        const loaderText = document.getElementById('globalLoaderText');
        const logsModal = new bootstrap.Modal(document.getElementById('logsModal'));
        const logsContent = document.getElementById('logsModalContent');
        const logsTitle = document.getElementById('logsModalTitle');

        const showLoader = (msg) => {
            loaderText.innerText = msg || 'Procesando...';
            loader.style.display = 'flex';
        };
        const hideLoader = () => {
            loader.style.display = 'none';
        };
        
        const showResult = (title, content, isError = false) => {
            logsTitle.innerText = title;
            logsContent.innerText = typeof content === 'object' ? JSON.stringify(content, null, 2) : content;
            logsContent.style.color = isError ? 'var(--danger)' : 'var(--text-muted)';
            logsModal.show();
        };

        const pwdModal = new bootstrap.Modal(document.getElementById('passwordModal'));
        const pwdRfc = document.getElementById('pwdRfc');
        const pwdRfcDisplay = document.getElementById('pwdRfcDisplay');
        const pwdNew = document.getElementById('pwdNew');

        document.querySelectorAll('.btn-action').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const action = btn.dataset.action;
                const rfc = btn.dataset.rfc;
                
                if (action === 'change-password-modal') {
                    pwdRfc.value = rfc;
                    pwdRfcDisplay.value = rfc;
                    pwdNew.value = '';
                    pwdModal.show();
                    return;
                }

                const method = btn.dataset.method;
                const needsConfirm = btn.dataset.confirm === 'true';

                if (needsConfirm) {
                    if (!confirm(`¿Estás seguro de que deseas ${action} la instancia ${rfc}?`)) return;
                    if (action === 'delete') {
                        if (!confirm('Esta acción es DESTRUCTIVA e IRREVERSIBLE. ¿Estás completamente seguro de eliminar bases de datos y archivos?')) return;
                    }
                }

                showLoader(`Ejecutando ${action} en ${rfc}...`);
                
                try {
                    const response = await fetch(`/instances/${rfc}/${action}`, {
                        method: method,
                        headers: {
                            'Accept': 'application/json'
                        }
                    });
                    
                    const data = await response.json();
                    hideLoader();
                    
                    if (data.success) {
                        if (action === 'delete') {
                            alert('Instancia eliminada correctamente.');
                            location.reload();
                        } else if (['restart', 'start', 'stop'].includes(action)) {
                            location.reload();
                        } else if (action.startsWith('backup-')) {
                            const filenames = data.files ? data.files.join('\\n') : data.filename;
                            showResult('Respaldo Exitoso', `Mensaje: ${data.message}\\nArchivo(s):\\n${filenames}\\n\\nSTDOUT:\\n${data.stdout || ''}`);
                        } else if (action === 'logs') {
                            showResult('Logs de Servicios', data.logs);
                        } else if (action === 'status') {
                            showResult('Estado de Servicios Docker', data.status);
                        } else if (action === 'config') {
                            showResult('Variables de Entorno (Protegidas)', data.config);
                        } else if (action === 'audits') {
                            showResult('Auditorías', data.audits);
                        }
                    } else {
                        showResult('Error en Operación', `Mensaje: ${data.error}\\nDetalles: ${data.details || ''}\\nSTDOUT: ${data.stdout || ''}\\nSTDERR: ${data.stderr || ''}`, true);
                    }
                } catch (err) {
                    hideLoader();
                    showResult('Error de Conexión', err.message, true);
                }
            });
        });

        document.getElementById('btnSavePassword').addEventListener('click', async () => {
            const rfc = pwdRfc.value;
            const newPassword = pwdNew.value;
            
            if (newPassword.length < 6) {
                alert('La contraseña debe tener al menos 6 caracteres');
                return;
            }
            
            pwdModal.hide();
            showLoader(`Cambiando contraseña API en ${rfc} y reiniciando servicios...`);
            
            try {
                const response = await fetch(`/instances/${rfc}/change-api-password`, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ password: newPassword })
                });
                
                const data = await response.json();
                hideLoader();
                
                if (data.success) {
                    alert('Contraseña actualizada exitosamente. Los servicios han sido reiniciados.');
                } else {
                    showResult('Error al cambiar contraseña', `Mensaje: ${data.error}\\nDetalles: ${data.details || ''}`, true);
                }
            } catch (err) {
                hideLoader();
                showResult('Error de Conexión', err.message, true);
            }
        });

        document.getElementById('btnImportInstances').addEventListener('click', async () => {
            if (!confirm('¿Deseas buscar e importar instancias existentes en la carpeta de clientes?')) return;
            
            showLoader('Escaneando e importando instancias...');
            try {
                const response = await fetch('/instances/import', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                
                const data = await response.json();
                hideLoader();
                
                if (data.success) {
                    const errorMsgs = data.errors.length > 0 ? `\\nErrores:\\n${data.errors.join('\\n')}` : '';
                    alert(`Importación completada.\\nNuevas importadas: ${data.imported}\\nOmitidas/Ya existentes: ${data.skipped}${errorMsgs}`);
                    if (data.imported > 0) location.reload();
                } else {
                    showResult('Error en Importación', `Mensaje: ${data.error}`, true);
                }
            } catch (err) {
                hideLoader();
                showResult('Error de Conexión', err.message, true);
            }
        });
    });
</script>

<%- include('partials/footer') %>
