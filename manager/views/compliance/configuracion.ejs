<!DOCTYPE html>
<html>
<head>
  <title>Compliance Center - Configuración</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f4f7f8; margin:0; padding:40px; color:#17384a; }
    .container { max-width:1200px; margin:auto; background:white; padding:30px; border-radius:10px; box-shadow:0 2px 10px rgba(0,0,0,.08); }
    nav a { margin-right:18px; font-weight:bold; color:#17384a; text-decoration:none; }
    h1 { margin-top:25px; }
    .grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-top:20px; }
    .card { border:1px solid #e2e8f0; border-radius:8px; padding:22px; }
    label { display:block; font-weight:bold; margin-top:12px; }
    input, select { width:100%; padding:10px; margin-top:6px; border:1px solid #cbd5e1; border-radius:5px; }
  </style>
</head>
<body>
  <div class="container">
    <nav>
      <a href="/compliance/dashboard">Dashboard</a>
      <a href="/compliance/auditorias">Auditorías</a>
      <a href="/compliance/evidencias">Evidencias</a>
      <a href="/compliance/herramientas">Herramientas</a>
      <a href="/compliance/configuracion">Configuración</a>
      <a href="/">Volver al Gestor</a>
    </nav>

    <h1>Compliance Center - Configuración</h1>
    <p>Configuración de perfiles, herramientas, exclusiones y políticas de reutilización.</p>

    <div class="grid">
      <div class="card">
        <h2>Perfil de Auditoría</h2>
        <label>Perfil predeterminado</label>
        <select>
          <option>Gobierno México PUI</option>
          <option>OWASP API Top 10</option>
          <option>Pentest Completo</option>
        </select>

        <label>Timeout por herramienta</label>
        <input value="3600 segundos" />
      </div>

      <div class="card">
        <h2>Almacenamiento</h2>
        <label>Directorio de evidencias</label>
        <input value="/app/data/security" />

        <label>Reutilizar evidencia por SHA256</label>
        <select>
          <option>Sí</option>
          <option>No</option>
        </select>
      </div>
    </div>
  </div>
</body>
</html>
