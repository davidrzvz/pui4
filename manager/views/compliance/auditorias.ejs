<!DOCTYPE html>
<html>
<head>
  <title>Compliance Center - Auditorías</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f4f7f8; margin:0; padding:40px; color:#17384a; }
    .container { max-width:1200px; margin:auto; background:white; padding:30px; border-radius:10px; box-shadow:0 2px 10px rgba(0,0,0,.08); }
    nav a { margin-right:18px; font-weight:bold; color:#17384a; text-decoration:none; }
    h1 { margin-top:25px; }
    .card { border:1px solid #e2e8f0; border-radius:8px; padding:22px; margin-top:20px; }
    .actions { display:flex; gap:15px; margin-top:20px; }
    .btn { background:#17384a; color:white; padding:12px 18px; border-radius:6px; text-decoration:none; display:inline-block; border: none; cursor: pointer; font-size: 16px; }
    .btn:hover { background: #1a4157; }
    .btn:disabled { background: #94a3b8; cursor: not-allowed; }
    .btn.secondary { background:#64748b; }
    .btn.secondary:hover { background:#475569; }
    table { width:100%; border-collapse:collapse; margin-top:20px; }
    th, td { padding:12px; border-bottom:1px solid #e2e8f0; text-align:left; }
    .status-badge { padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; color: white; }
    .status-pending { background: #f59e0b; }
    .status-running { background: #3b82f6; }
    .status-finished { background: #10b981; }
    .status-failed { background: #ef4444; }
  </style>
</head>
<body>
  <div class="container">
    <nav>
      <a href="/compliance/dashboard">Dashboard</a>
      <a href="/compliance/auditorias">Auditorías</a>
      <a href="/compliance/evidencias">Evidencias</a>
      <a href="/compliance/herramientas">Herramientas</a>
      <a href="/compliance/configuracion">Configuración</a>
      <a href="/">Volver al Gestor</a>
    </nav>

    <h1>Compliance Center - Auditorías</h1>
    <p>Desde aquí se ejecutarán auditorías de código SAST/SCA y auditorías de instancia DAST.</p>

    <div class="card">
      <h2>Nueva Auditoría</h2>
      <p>Selecciona el tipo de auditoría que deseas ejecutar.</p>
      <div class="actions">
        <!-- Assuming target_id = 1 as default for now, full form will be added in task 4/5 -->
        <button class="btn" id="btn-code-audit">Auditoría de Código SAST/SCA</button>
        <button class="btn secondary" id="btn-instance-audit">Auditoría de Instancia DAST</button>
      </div>
    </div>

    <div class="card">
      <h2>Historial</h2>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Fecha</th>
            <th>Tipo / Perfil</th>
            <th>Instancia</th>
            <th>Progreso</th>
            <th>Estado</th>
            <th>Evidencia</th>
          </tr>
        </thead>
        <tbody id="history-tbody">
          <tr>
            <td colspan="7">Cargando historial...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    async function fetchHistory() {
      try {
        const response = await fetch('/compliance/api/audits/history');
        const result = await response.json();
        
        const tbody = document.getElementById('history-tbody');
        tbody.innerHTML = '';
        
        if (result.success && result.data.length > 0) {
          result.data.forEach(audit => {
            const date = new Date(audit.date).toLocaleString();
            let statusClass = 'status-pending';
            if (audit.status === 'Running') statusClass = 'status-running';
            if (audit.status === 'finished' || audit.status === 'Finished') statusClass = 'status-finished';
            if (audit.status === 'failed' || audit.status === 'Failed') statusClass = 'status-failed';
            
            let evidenceLink = '-';
            if (audit.status === 'finished' || audit.status === 'Finished') {
              evidenceLink = `<a href="/compliance/evidencias">Ver en Evidencias</a>`;
            }

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>#${audit.id}</td>
              <td>${date}</td>
              <td>${audit.profile}</td>
              <td>${audit.instance_name || 'N/A'}</td>
              <td>${audit.progress || 0}%</td>
              <td><span class="status-badge ${statusClass}">${audit.status || 'Pending'}</span></td>
              <td>${evidenceLink}</td>
            `;
            tbody.appendChild(tr);
          });
        } else {
          tbody.innerHTML = '<tr><td colspan="7">Aún no hay auditorías registradas.</td></tr>';
        }
      } catch (error) {
        console.error('Error fetching history:', error);
      }
    }

    document.getElementById('btn-code-audit').addEventListener('click', async (e) => {
      e.target.disabled = true;
      e.target.innerText = 'Iniciando...';
      try {
        const res = await fetch('/compliance/api/auditorias/code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target_id: 1 }) // TODO: dynamic target_id
        });
        const data = await res.json();
        if(data.success) {
          alert('Auditoría de Código iniciada (ID: ' + (data.data.auditId || data.data.code_version_id) + ')');
        } else {
          alert('Error: ' + data.error);
        }
      } catch (error) {
        alert('Request failed');
      }
      e.target.disabled = false;
      e.target.innerText = 'Auditoría de Código SAST/SCA';
      fetchHistory();
    });

    document.getElementById('btn-instance-audit').addEventListener('click', async (e) => {
      e.target.disabled = true;
      e.target.innerText = 'Iniciando...';
      try {
        const res = await fetch('/compliance/api/auditorias/instance', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target_id: 1, profile: 'Instance Audit' }) // TODO: dynamic target_id
        });
        const data = await res.json();
        if(data.success) {
          alert('Auditoría de Instancia iniciada (ID: ' + data.data.auditId + ')');
        } else {
          alert('Error: ' + data.error);
        }
      } catch (error) {
        alert('Request failed');
      }
      e.target.disabled = false;
      e.target.innerText = 'Auditoría de Instancia DAST';
      fetchHistory();
    });

    // Initial load
    fetchHistory();
    
    // Auto-refresh every 5 seconds
    setInterval(fetchHistory, 5000);
  </script>
</body>
</html>
