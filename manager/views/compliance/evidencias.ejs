<!DOCTYPE html>
<html>
<head>
  <title>Compliance Center - Evidencias</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f4f7f8; margin:0; padding:40px; color:#17384a; }
    .container { max-width:1200px; margin:auto; background:white; padding:30px; border-radius:10px; box-shadow:0 2px 10px rgba(0,0,0,.08); }
    nav a { margin-right:18px; font-weight:bold; color:#17384a; text-decoration:none; }
    h1 { margin-top:25px; }
    .card { border:1px solid #e2e8f0; border-radius:8px; padding:22px; margin-top:20px; }
    table { width:100%; border-collapse:collapse; margin-top:20px; }
    th, td { padding:12px; border-bottom:1px solid #e2e8f0; text-align:left; }
    .badge { padding:5px 10px; border-radius:5px; background:#e2e8f0; }
    .download-links a { margin-right: 10px; text-decoration: none; color: #3b82f6; font-weight: bold; font-size: 14px; }
    .download-links a:hover { text-decoration: underline; }
    .status-badge { padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; color: white; }
    .status-finished { background: #10b981; }
    .status-failed { background: #ef4444; }
  </style>
</head>
<body>
  <div class="container">
    <nav>
      <a href="/compliance/dashboard">Dashboard</a>
      <a href="/compliance/auditorias">Auditorías</a>
      <a href="/compliance/evidencias">Evidencias</a>
      <a href="/compliance/herramientas">Herramientas</a>
      <a href="/compliance/configuracion">Configuración</a>
      <a href="/">Volver al Gestor</a>
    </nav>

    <h1>Compliance Center - Evidencias</h1>
    <p>Paquetes generados para entregar al Gobierno: reportes PDF, metadata, manifest y ZIP final.</p>

    <div class="card">
      <h2>Expedientes Generados</h2>
      <table>
        <thead>
          <tr>
            <th>Auditoría ID</th>
            <th>Fecha</th>
            <th>Perfil</th>
            <th>Estado</th>
            <th>Descargas</th>
          </tr>
        </thead>
        <tbody id="evidences-tbody">
          <tr>
            <td colspan="5">Cargando evidencias...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    async function fetchEvidences() {
      try {
        const response = await fetch('/compliance/api/audits/history');
        const result = await response.json();
        
        const tbody = document.getElementById('evidences-tbody');
        tbody.innerHTML = '';
        
        if (result.success && result.data && result.data.length > 0) {
          // Filter only finished or failed
          const evidences = result.data.filter(a => a.status === 'Finished' || a.status === 'finished' || a.status === 'Failed' || a.status === 'failed');
          
          if (evidences.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5">Aún no hay evidencias generadas.</td></tr>';
            return;
          }

          evidences.forEach(audit => {
            const date = new Date(audit.date).toLocaleString();
            let statusClass = (audit.status.toLowerCase() === 'finished') ? 'status-finished' : 'status-failed';
            
            // Generate download links based on id
            const downloadLinks = `
              <div class="download-links">
                <a href="/compliance/api/evidences/${audit.id}/zip">⬇️ Paquete ZIP</a>
                <a href="/compliance/api/evidences/${audit.id}/executive">📄 Reporte Ejecutivo</a>
                <a href="/compliance/api/evidences/${audit.id}/technical">📄 Reporte Técnico</a>
              </div>
            `;

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>#${audit.id}</td>
              <td>${date}</td>
              <td>${audit.profile}</td>
              <td><span class="status-badge ${statusClass}">${audit.status}</span></td>
              <td>${downloadLinks}</td>
            `;
            tbody.appendChild(tr);
          });
        } else {
          tbody.innerHTML = '<tr><td colspan="5">Aún no hay evidencias generadas.</td></tr>';
        }
      } catch (error) {
        console.error('Error fetching evidences:', error);
      }
    }

    fetchEvidences();
  </script>
</body>
</html>
