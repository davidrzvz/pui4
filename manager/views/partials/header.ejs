<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'PUI Manager' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { min-height: 100vh; display: flex; flex-direction: column; }
        .sidebar { min-width: 250px; background: #1e1e2f; color: #fff; }
        .sidebar a { color: #cfcfd4; text-decoration: none; padding: 10px 20px; display: block; }
        .sidebar a:hover, .sidebar a.active { background: #2d2d44; color: #fff; }
        .main-content { flex: 1; background: #0f0f1a; color: #e1e1e6; }
        .card { background: #1e1e2f; border: none; }
        .table { color: #e1e1e6; }
        .table-striped>tbody>tr:nth-of-type(odd)>* { color: #e1e1e6; }
    </style>
</head>
<body>
    <div class="d-flex flex-grow-1">
        <%- include('sidebar') %>
        <main class="main-content p-4">
            <% if (locals.error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= locals.error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <% if (locals.success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= locals.success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
